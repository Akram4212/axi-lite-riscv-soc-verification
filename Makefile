# ============================================================
# AXI-Lite RISC-V SoC Verification Platform
# Makefile for linting, simulation, regression, and cleanup
#
# Current milestone:
#   - GPIO AXI-Lite peripheral
#   - cocotb testbench
#   - Verilator simulation
# ============================================================

# ----------------------------
# Project directories
# ----------------------------
PWD_DIR      := $(shell pwd)
RTL_DIR      := $(PWD_DIR)/rtl
TB_DIR       := $(PWD_DIR)/tb
INC_DIR      := $(PWD_DIR)/include
SCRIPT_DIR   := $(PWD_DIR)/scripts
FIRMWARE_DIR := $(PWD_DIR)/firmware

# ----------------------------
# Tool configuration
# ----------------------------
SIM ?= verilator
TOPLEVEL_LANG ?= verilog

# Default waveform file generated by cocotb/Verilator
WAVE_FILE ?= dump.vcd

# ----------------------------
# RTL sources
# ----------------------------
GPIO_RTL := $(RTL_DIR)/gpio.sv

# Future files
TIMER_RTL      := $(RTL_DIR)/timer.sv
AXI_INTC_RTL   := $(RTL_DIR)/axi_lite_interconnect.sv
SOC_TOP_RTL    := $(RTL_DIR)/soc_top.sv
RAM_RTL        := $(RTL_DIR)/ram.sv
RISCV_CORE_RTL := $(RTL_DIR)/simple_riscv_core.sv

# ----------------------------
# Verilator options
# ----------------------------
VERILATOR_LINT_FLAGS := --lint-only -Wall -I$(INC_DIR)

# Cocotb / Verilator compile options
EXTRA_ARGS += -Wall
EXTRA_ARGS += -I$(INC_DIR)

ifeq ($(SIM),verilator)
EXTRA_ARGS += --trace
EXTRA_ARGS += --trace-structs
endif

# ============================================================
# Default target
# ============================================================

.PHONY: help
help:
	@echo ""
	@echo "AXI-Lite RISC-V SoC Verification Platform"
	@echo "============================================================"
	@echo "Available targets:"
	@echo ""
	@echo "  make lint_gpio        Lint GPIO RTL with Verilator"
	@echo "  make test_gpio        Run GPIO cocotb test"
	@echo "  make waves            Open waveform using GTKWave"
	@echo "  make regression       Run all implemented tests"
	@echo "  make clean            Remove simulation/build outputs"
	@echo "  make status           Show project/tool status"
	@echo ""
	@echo "Future targets:"
	@echo "  make lint_timer       Placeholder for timer lint"
	@echo "  make test_timer       Placeholder for timer test"
	@echo "  make test_axi         Placeholder for AXI interconnect test"
	@echo "  make test_soc         Placeholder for full SoC test"
	@echo ""

# ============================================================
# Status / tool checks
# ============================================================

.PHONY: status
status:
	@echo ""
	@echo "Project directory: $(PWD_DIR)"
	@echo "RTL directory:     $(RTL_DIR)"
	@echo "TB directory:      $(TB_DIR)"
	@echo "Include directory: $(INC_DIR)"
	@echo ""
	@echo "Checking tools..."
	@which verilator || true
	@which gtkwave || true
	@which python3 || true
	@which cocotb-config || true
	@which yosys || true
	@echo ""

# ============================================================
# Lint targets
# ============================================================

.PHONY: lint_gpio
lint_gpio:
	verilator $(VERILATOR_LINT_FLAGS) $(GPIO_RTL)

.PHONY: lint_timer
lint_timer:
	@if [ -f "$(TIMER_RTL)" ]; then \
		verilator $(VERILATOR_LINT_FLAGS) $(TIMER_RTL); \
	else \
		echo "timer.sv not implemented yet."; \
	fi

.PHONY: lint_axi
lint_axi:
	@if [ -f "$(AXI_INTC_RTL)" ]; then \
		verilator $(VERILATOR_LINT_FLAGS) $(AXI_INTC_RTL); \
	else \
		echo "axi_lite_interconnect.sv not implemented yet."; \
	fi

.PHONY: lint_soc
lint_soc:
	@if [ -f "$(SOC_TOP_RTL)" ]; then \
		verilator $(VERILATOR_LINT_FLAGS) \
			-I$(INC_DIR) \
			$(SOC_TOP_RTL) \
			$(AXI_INTC_RTL) \
			$(GPIO_RTL) \
			$(TIMER_RTL) \
			$(RAM_RTL) \
			$(RISCV_CORE_RTL); \
	else \
		echo "soc_top.sv not implemented yet."; \
	fi

.PHONY: lint
lint: lint_gpio
	@echo "Implemented lint checks completed."

# ============================================================
# Cocotb simulation targets
# ============================================================

.PHONY: test_gpio
test_gpio:
	$(MAKE) sim \
		SIM=$(SIM) \
		TOPLEVEL_LANG=$(TOPLEVEL_LANG) \
		TOPLEVEL=gpio \
		MODULE=test_gpio \
		VERILOG_SOURCES="$(GPIO_RTL)" \
		EXTRA_ARGS="$(EXTRA_ARGS)"

.PHONY: test_timer
test_timer:
	@if [ -f "$(TIMER_RTL)" ] && [ -f "$(TB_DIR)/test_timer.py" ]; then \
		$(MAKE) sim \
			SIM=$(SIM) \
			TOPLEVEL_LANG=$(TOPLEVEL_LANG) \
			TOPLEVEL=timer \
			MODULE=test_timer \
			VERILOG_SOURCES="$(TIMER_RTL)" \
			EXTRA_ARGS="$(EXTRA_ARGS)"; \
	else \
		echo "Timer RTL/testbench not implemented yet."; \
	fi

.PHONY: test_axi
test_axi:
	@if [ -f "$(AXI_INTC_RTL)" ] && [ -f "$(TB_DIR)/test_axi_lite.py" ]; then \
		$(MAKE) sim \
			SIM=$(SIM) \
			TOPLEVEL_LANG=$(TOPLEVEL_LANG) \
			TOPLEVEL=axi_lite_interconnect \
			MODULE=test_axi_lite \
			VERILOG_SOURCES="$(AXI_INTC_RTL) $(GPIO_RTL) $(TIMER_RTL)" \
			EXTRA_ARGS="$(EXTRA_ARGS)"; \
	else \
		echo "AXI interconnect RTL/testbench not implemented yet."; \
	fi

.PHONY: test_soc
test_soc:
	@if [ -f "$(SOC_TOP_RTL)" ] && [ -f "$(TB_DIR)/test_soc_program.py" ]; then \
		$(MAKE) sim \
			SIM=$(SIM) \
			TOPLEVEL_LANG=$(TOPLEVEL_LANG) \
			TOPLEVEL=soc_top \
			MODULE=test_soc_program \
			VERILOG_SOURCES="$(SOC_TOP_RTL) $(RISCV_CORE_RTL) $(AXI_INTC_RTL) $(GPIO_RTL) $(TIMER_RTL) $(RAM_RTL)" \
			EXTRA_ARGS="$(EXTRA_ARGS)"; \
	else \
		echo "SoC RTL/testbench not implemented yet."; \
	fi

# ============================================================
# Regression
# ============================================================

.PHONY: regression
regression: clean lint_gpio test_gpio
	@echo ""
	@echo "============================================================"
	@echo "Regression completed."
	@echo "Implemented tests passed."
	@echo "============================================================"

# ============================================================
# Waveform viewing
# ============================================================

.PHONY: waves
waves:
	@if [ -f "$(WAVE_FILE)" ]; then \
		gtkwave $(WAVE_FILE); \
	elif [ -f "dump.fst" ]; then \
		gtkwave dump.fst; \
	else \
		echo "No waveform file found. Run make test_gpio first."; \
	fi

# ============================================================
# Yosys synthesis check
# ============================================================

.PHONY: synth_gpio
synth_gpio:
	yosys -p "read_verilog -sv -I$(INC_DIR) $(GPIO_RTL); synth; stat"

# ============================================================
# Cleanup
# ============================================================

.PHONY: clean
clean:
	rm -rf sim_build
	rm -rf obj_dir
	rm -rf __pycache__
	rm -rf .pytest_cache
	rm -f results.xml
	rm -f dump.vcd
	rm -f dump.fst
	rm -f dump.lxt
	rm -f *.vcd
	rm -f *.fst
	rm -f *.lxt
	rm -f *.log
	rm -f *.xml
	rm -f transcript
	rm -f *.jou
	rm -f *.wdb

# ============================================================
# Include cocotb simulator Makefile
# ============================================================

include $(shell cocotb-config --makefiles)/Makefile.sim